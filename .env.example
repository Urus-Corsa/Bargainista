# Copy this file to .env and fill in real values before running the stack.
# .env is gitignored — never commit secrets.

# ── Database ─────────────────────────────────────────────────────────────────
# Inside Docker Compose, host is the service name "postgres".
# For local development outside Docker, use "localhost".
DATABASE_URL=postgresql+asyncpg://bargainista:bargainista@postgres:5432/bargainista

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── MCP Server ───────────────────────────────────────────────────────────────
# Inside Docker Compose the MCP server runs as service "mcp" on port 8001.
# For local development outside Docker, use http://localhost:8001.
MCP_SERVER_URL=http://mcp:8001

# ── Admin API Key ─────────────────────────────────────────────────────────────
# Protects depreciation config CRUD endpoints (brand modifiers, variant overrides).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=your-secret-key-here

# ── AI API Key (required from Phase 3 onward) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── LangSmith tracing (optional but recommended) ─────────────────────────────
# Get your API key at smith.langchain.com → Settings → API Keys
# Set LANGCHAIN_TRACING_V2=false (or remove these lines) to disable tracing.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=bargainista
LANGCHAIN_HIDE_INPUTS=true    # prevents 422 errors from base64 image payloads exceeding LangSmith's 25MB field limit

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
